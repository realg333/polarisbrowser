# Polaris API — variáveis de ambiente (Sprint 4: Cloud + Billing)
# Setup: cp .env.example .env  (ou copie manualmente no Windows)

# ── Servidor ────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
API_URL=http://localhost:3001
APP_URL=http://localhost:5173

# ── Supabase (obrigatório) ──────────────────────────────────
# Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Dashboard → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Aplique as migrations em supabase/migrations/ no seu projeto Supabase.

# ── Stripe (opcional em dev) ────────────────────────────────
# Se STRIPE_SECRET_KEY estiver vazio, billing fica desabilitado.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_UNLIMITED_MONTHLY=price_...
STRIPE_PRICE_UNLIMITED_YEARLY=price_...

# ── Licença offline ─────────────────────────────────────────
# DEVE ser idêntico ao LICENSE_SIGNING_SECRET em apps/desktop/.env
LICENSE_SIGNING_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
