# Polaris Desktop — variáveis de ambiente
# Setup: cp .env.example .env  (ou copie manualmente no Windows)

# ── Supabase (auth) ─────────────────────────────────────────
# Obrigatório apenas para login/sync cloud. Modo offline funciona sem isso.
# Dashboard → Settings → API → Project URL + anon/public key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── API cloud ───────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
POLARIS_API_URL=http://localhost:3001

# ── Licença offline ─────────────────────────────────────────
# DEVE ser idêntico ao LICENSE_SIGNING_SECRET em apps/api/.env
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
LICENSE_SIGNING_SECRET=change-me-to-a-long-random-secret-at-least-32-chars
